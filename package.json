{
  "name": "vscode-solution-explorer",
  "displayName": "vscode-solution-explorer",
  "description": "Visual Studio .sln file explorer for Visual Studio Code",
  "version": "9.9.9",
  "license": "MIT",
  "publisher": "fernandoescolar",
  "icon": "images/icon.png",
  "author": {
    "email": "f.escolar@hotmail.com",
    "name": "Fernando Escolar",
    "url": "http://fernandoescolar.github.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fernandoescolar/vscode-solution-explorer"
  },
  "bugs": {
    "url": "https://github.com/fernandoescolar/vscode-solution-explorer/issues",
    "email": "f.escolar@hotmail.com"
  },
  "engines": {
    "vscode": "^1.99.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.sln",
    "workspaceContains:**/*.slnx",
    "*"
  ],
  "main": "./out/extension",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sln_explorer",
          "title": "%viewContainer.sln_explorer.title%",
          "icon": "images/activity-icon.png",
          "when": "solutionExplorer.viewInActivityBar && solutionExplorer.loadedFlag"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "slnexpl",
          "name": "%view.slnexpl.name%",
          "when": "solutionExplorer.viewInExplorer && solutionExplorer.loadedFlag"
        }
      ],
      "sln_explorer": [
        {
          "id": "slnbrw",
          "name": "%view.slnbrw.name%",
          "when": "solutionExplorer.viewInActivityBar && solutionExplorer.loadedFlag"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "slnexpl",
        "contents": "%viewsWelcome.slnexpl.contents%"
      },
      {
        "view": "slnbrw",
        "contents": "%viewsWelcome.slnbrw.contents%"
      }
    ],
    "commands": [
      {
        "command": "solutionExplorer.openSelectedSolution",
        "title": "%command.openSelectedSolution.title%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "solutionExplorer.openSolution",
        "title": "%command.openSolution.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "solutionExplorer.refresh",
        "title": "%command.refresh.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(refresh)"
      },
      {
        "command": "solutionExplorer.collapseAll",
        "title": "%command.collapseAll.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(collapse-all)"
      },
      {
        "command": "solutionExplorer.openFile",
        "title": "%command.openFile.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(edit)"
      },
      {
        "command": "solutionExplorer.openFileAndFocus",
        "title": "%command.openFileAndFocus.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(edit)"
      },
      {
        "command": "solutionExplorer.renameFile",
        "title": "%command.renameFile.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.revealFileInOS",
        "title": "%command.revealFileInOS.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.addSolutionFile",
        "title": "%command.addSolutionFile.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(new-file)"
      },
      {
        "command": "solutionExplorer.deleteSolutionFile",
        "title": "%command.deleteSolutionFile.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(trash)"
      },
      {
        "command": "solutionExplorer.deleteFile",
        "title": "%command.deleteFile.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(trash)"
      },
      {
        "command": "solutionExplorer.createDirectoryPackages",
        "title": "%command.createDirectoryPackages.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.editMsBuildProperties",
        "title": "%command.editMsBuildProperties.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(settings-gear)"
      },
      {
        "command": "solutionExplorer.createFile",
        "title": "%command.createFile.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(new-file)"
      },
      {
        "command": "solutionExplorer.createFileAbove",
        "title": "%command.createFileAbove.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(new-file)"
      },
      {
        "command": "solutionExplorer.createFileBelow",
        "title": "%command.createFileBelow.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(new-file)"
      },
      {
        "command": "solutionExplorer.renameFolder",
        "title": "%command.renameFolder.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.deleteFolder",
        "title": "%command.deleteFolder.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.createFolder",
        "title": "%command.createFolder.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(new-folder)"
      },
      {
        "command": "solutionExplorer.moveFile",
        "title": "%command.moveFile.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.moveFileUp",
        "title": "%command.moveFileUp.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(arrow-up)"
      },
      {
        "command": "solutionExplorer.moveFileDown",
        "title": "%command.moveFileDown.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(arrow-down)"
      },
      {
        "command": "solutionExplorer.moveFolder",
        "title": "%command.moveFolder.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.addPackage",
        "title": "%command.addPackage.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(add)"
      },
      {
        "command": "solutionExplorer.updatePackageVersion",
        "title": "%command.updatePackageVersion.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.removePackage",
        "title": "%command.removePackage.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(trash)"
      },
      {
        "command": "solutionExplorer.updatePackagesVersion",
        "title": "%command.updatePackagesVersion.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.addProjectReference",
        "title": "%command.addProjectReference.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(add)"
      },
      {
        "command": "solutionExplorer.removeProjectReference",
        "title": "%command.removeProjectReference.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(trash)"
      },
      {
        "command": "solutionExplorer.createNewSolution",
        "title": "%command.createNewSolution.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.addNewProject",
        "title": "%command.addNewProject.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.addNewProjectUI",
        "title": "%command.addNewProjectUI.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.addExistingProject",
        "title": "%command.addExistingProject.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.createSolutionFolder",
        "title": "%command.createSolutionFolder.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.installTemplates",
        "title": "%command.installTemplates.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.renameSolutionItem",
        "title": "%command.renameSolutionItem.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.moveToSolutionFolder",
        "title": "%command.moveToSolutionFolder.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.removeSolutionFolder",
        "title": "%command.removeSolutionFolder.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.removeProject",
        "title": "%command.removeProject.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.copy",
        "title": "%command.copy.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.duplicate",
        "title": "%command.duplicate.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.paste",
        "title": "%command.paste.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.build",
        "title": "%command.build.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.clean",
        "title": "%command.clean.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.pack",
        "title": "%command.pack.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.publish",
        "title": "%command.publish.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.restore",
        "title": "%command.restore.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.run",
        "title": "%command.run.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.watchRun",
        "title": "%command.watchRun.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.test",
        "title": "%command.test.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.showActiveFileInExplorer",
        "title": "%command.showActiveFileInExplorer.title%",
        "category": "%category.solutionExplorer%",
        "icon": "$(eye)"
      },
      {
        "command": "solutionExplorer.focus",
        "title": "%command.focus.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.deleteMultiple",
        "title": "%command.deleteMultiple.title%",
        "category": "%category.solutionExplorer%"
      },
      {
        "command": "solutionExplorer.invalidateNugetCache",
        "title": "%command.invalidateNugetCache.title%",
        "category": "%category.solutionExplorer%"
