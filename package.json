    "@types/webpack-env": "^1.17.0",
    "@typescript-eslint/eslint-plugin": "^5.31.0",
    "@typescript-eslint/parser": "^5.31.0",
    "@vscode/l10n-dev": "^0.0.35",
    "eslint": "^8.20.0",
    "process": "0.11.10",
    "ts-loader": "^9.3.1",
    "typescript": "^4.7.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^4.10.0"
  },
  "dependencies": {
    "@types/uuid": "^8.3.4",
    "clipboardy": "^3.0.0",
    "eol": "^0.9.1",
    "handlebars": "^4.7.9",
    "iconv-lite": "^0.6.3",
    "node-fetch": "^3.2.10",
